{
  "name": "fastify-nodejs-example",
  "version": "1.0.0",
  "description": "Example CRUD API using Fastify Web framework",
  "engines": {
    "node": ">=24.10.0",
    "npm": ">=10.9.2",
    "bun": ">=1"
  },
  "type": "module",
  "scripts": {
    "start:dev": "node --trace-deprecation --watch ./src/server.js",
    "start:prod": "node ./src/server.js",
    "start:multi": "node ./src/serverMulti.js",
    "lint": "quick-lint-js ./src/*.js ./test/*.js",
    "test": "tsc && bun test && node ./test/all.js",
    "format": "prettier **/*.js --write",
    "formatCheck": "prettier **/*.js --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viktor-podzigun/fastify-nodejs-example.git"
  },
  "keywords": [
    "nodejs",
    "fastify",
    "HTTP",
    "api",
    "assignments"
  ],
  "author": "viktorpodzigun",
  "license": "MIT",
  "dependencies": {
    "fastify": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "c8": "^7.14.0",
    "prettier": "^3.8.1",
    "quick-lint-js": "^3.2.0",
    "typescript": "^5.9.3"
  }
}
